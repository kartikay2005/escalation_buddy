# Escalation Management System Configuration
# All variables below are OPTIONAL - system runs in demo mode without them

# Google Sheets Configuration (optional - enables persistent storage)
# GOOGLE_SHEET_ID=your_sheet_id_here
# SHEET_NAME=Escalations
# GOOGLE_CREDENTIALS_PATH=./credentials.json

# Ollama Configuration (optional - enables AI triage, falls back to rules)
# OLLAMA_URL=http://localhost:11434

# Flask Configuration (optional)
# FLASK_PORT=5000

# Streamlit Configuration (optional)
# STREAMLIT_SERVER_PORT=8501
